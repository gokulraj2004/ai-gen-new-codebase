# ── Application ──
APP_NAME=New Codebase
APP_ENV=development
DEBUG=true
SECRET_KEY=<generate-a-secure-random-secret-key>

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_NAME=new_codebase
DB_USER=postgres
DB_PASSWORD=<set-a-secure-database-password>
DATABASE_URL=postgresql+asyncpg://postgres:<set-a-secure-database-password>@db:5432/new_codebase

# ── Authentication ──
JWT_SECRET_KEY=<generate-a-secure-random-jwt-secret>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173